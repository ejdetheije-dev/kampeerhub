# OpenRouter API key for LLM chat functionality
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Set to "true" for deterministic mock LLM responses (testing/CI)
LLM_MOCK=false

# Override database path (default: /app/database/kampeerhub.db inside Docker)
# Set this for local development outside Docker to avoid writing to /app/
# DATABASE_PATH=./database/kampeerhub.db

# Mapbox token for 3D satellite flyover in DetailOverlay (free tier: 50k map loads/month)
# Get your token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
